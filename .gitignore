```gitignore
# ==========================
# Dependencies
# ==========================
node_modules/

# ==========================
# Environment Variables
# ==========================
.env
.env.local
.env.development.local
.env.test.local
.env.production.local

# ==========================
# Logs
# ==========================
logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# ==========================
# Runtime Files
# ==========================
pids
*.pid
*.seed
*.pid.lock

# ==========================
# Build Files
# ==========================
dist/
build/

# ==========================
# Vite
# ==========================
.vite/

# ==========================
# Coverage
# ==========================
coverage/
.nyc_output/

# ==========================
# IDE Files
# ==========================
.vscode/
.idea/
*.suo
*.ntvs*
*.njsproj
*.sln

# ==========================
# OS Files
# ==========================
.DS_Store
Thumbs.db
Desktop.ini

# ==========================
# Temporary Files
# ==========================
tmp/
temp/
.cache/

# ==========================
# Redis
# ==========================
dump.rdb

# ==========================
# MongoDB Local
# ==========================
data/

# ==========================
# Optional Lock Files
# (Keep only the one your project uses)
# ==========================
# package-lock.json
# yarn.lock
# pnpm-lock.yaml

# ==========================
# Misc
# ==========================
*.local
*.swp
*.swo
```
